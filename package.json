{
  "name": "@taxora/sdk",
  "version": "1.0.3",
  "description": "Taxora VAT Validation API SDK for Node.js",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.3.3",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "taxora",
    "vat",
    "validation",
    "vat-validation",
    "eu-vat",
    "tax",
    "sdk",
    "typescript",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theconcept-technologies/taxora-sdk-node.git"
  },
  "homepage": "https://taxora.io",
  "bugs": {
    "url": "https://github.com/theconcept-technologies/taxora-sdk-node/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
